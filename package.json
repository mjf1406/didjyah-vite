{
  "name": "vite-app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "ps": "bunx instant-cli@latest push schema",
    "pp": "bunx instant-cli@latest push perms",
    "pps": "bun run ps && bun run pp"
  },
  "dependencies": {
    "@fontsource-variable/montserrat": "^5.2.8",
